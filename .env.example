SECRET_KEY=your-secret-key-here
# For local runserver: use True so static + /media/ are served. Docker web service forces DEBUG in compose.
DEBUG=True
# If DEBUG is False, set true to still serve /media/ from the app (not for public production)
SERVE_MEDIA_IN_APP=True
DB_NAME=boardgamenexus
DB_USER=postgres
DB_PASSWORD=yourpassword
# Local runserver: localhost. Docker app uses DB_HOST=db — use the same DB or run:
#   docker compose exec web python manage.py createsuperuser
DB_HOST=localhost
DB_PORT=5432
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
DEFAULT_FROM_EMAIL=noreply@boardgamenexus.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
ALLOWED_HOSTS=localhost,127.0.0.1