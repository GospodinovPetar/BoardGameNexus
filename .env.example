SECRET_KEY=your-secret-key-here
DB_NAME=your_database_name
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Docker Compose (docker compose up) reads this same .env file for ${DB_*}
# substitution. The web service overrides DB_HOST to `db` automatically.
# Keep DB_NAME, DB_USER, and DB_PASSWORD aligned with what Postgres should create.